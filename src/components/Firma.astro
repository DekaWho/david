---
import OptinRobame from './OptinRobame.astro';

// `id` opcional: PostLayout pasa "post-end" cuando esta firma cierra el
// post, los .mdx la insertan sin id en mitad del artículo para que no haya
// dos elementos con el mismo id en la página.
const { id } = Astro.props;
---

<section class="post-firma" id={id}>
    <img
        class="hero-photo"
        src="/imgs/profile-pic.webp"
        alt="David Varea"
        loading="lazy"
    />
    <div>
        <p class="firma-nombre">David Varea</p>
        <p class="firma-mano">
            Me he gastado <span class="mark-amarillo"
                >19.970€ en cursos y mentorías</span
            > de marketing directo, IA y emprendimiento para que <u
                >tú no tengas que hacerlo</u
            >
        </p>
    </div>

    <img
        class="banner-proof"
        src="/imgs/robame-tamano.jpg"
        alt="Captura del explorador de Windows mostrando 254 GB en la carpeta de cursos"
        loading="lazy"
        decoding="async"
    />

    <OptinRobame />
</section>

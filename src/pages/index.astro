---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import { DESCRIPCION_19K } from "../data/bio.js";
---

<BaseLayout
    titulo="David Varea | Director de marketing en las sombras"
    canonical="/"
    ogTitle="🤝 David Varea"
    ogDescription={DESCRIPCION_19K}
    ogUrl="https://davidvarea.com"
>
    <main class="stage">
        <section class="hero-card">
            <div class="hero-photo-wrap">
                <img
                    class="hero-photo"
                    src="/imgs/profile-pic.webp"
                    alt="David Varea"
                />
            </div>

            <h1 class="hero-headline">
                Mis clientes han facturado
                <span class="hl-squiggle">
                    <span class="squiggle-text">2.4 millones</span>
                    <svg
                        class="squiggle-svg"
                        viewBox="0 0 140 10"
                        preserveAspectRatio="none"
                        aria-hidden="true"
                    >
                        <path
                            d="M2 5 Q 35 1 70 5 T 138 5"
                            stroke-width="2.4"
                            fill="none"
                            stroke-linecap="round"></path>
                    </svg>
                </span>
                de € con mi ayuda
            </h1>

            <div class="postit-wrap">
                <div class="postit">
                    <span class="tape" aria-hidden="true"></span>
                    Este título <span class="bold"
                        >va para el David Varea de hace 2 años:</span
                    > El que apostó por sí mismo cuando lo seguro era conformarse.
                </div>
            </div>
        </section>

        <span class="section-arrow" aria-hidden="true"></span>

        <div class="section-heading">
            <span class="caret">▾</span>
            ¿Qué te trae por aquí?
        </div>

        <nav class="blocks" aria-label="Secciones">
            <div class="block-group">
                <button
                    type="button"
                    class="block block--primary block-toggle"
                    aria-expanded="false"
                    aria-controls="sub-consultoria"
                >
                    <span class="handle" aria-hidden="true">⋮⋮</span>
                    <img class="icon" src="/imgs/svg/fire.svg" alt="🔥" />
                    <span class="body">
                        <span class="title">Consultoría</span>
                        <span class="subtitle-hand"
                            >Pulsa para ver si tengo disponibilidad</span
                        >
                    </span>
                    <span class="arrow arrow--toggle" aria-hidden="true">▾</span
                    >
                </button>

                <div class="subblocks" id="sub-consultoria">
                    <div class="subblocks-inner">
                        {/* Consultoría en pausa: las dos vías se ocultan
                            mientras no hay hueco. Para reactivarlas, descomentar
                            estos dos <a> y quitar la tarjeta de aviso de abajo. */}
                        {/*
                        <a
                            class="block block--secondary block--sub"
                            href="/servicios"
                            target="_blank"
                            rel="noopener"
                            draggable="false"
                        >
                            <img
                                class="icon"
                                src="/imgs/svg/robot.svg"
                                alt="🤖"
                            />
                            <span class="body">
                                <span class="title"
                                    >Aplicar IA a tu negocio</span
                                >
                                <span class="subtitle-hand"
                                    >automatiza con Claude Code</span
                                >
                            </span>
                            <span class="arrow" aria-hidden="true">→</span>
                        </a>

                        <a
                            class="block block--secondary block--sub"
                            href="/servicios"
                            target="_blank"
                            rel="noopener"
                            draggable="false"
                        >
                            <img
                                class="icon"
                                src="/imgs/svg/money-bag.svg"
                                alt="💰"
                            />
                            <span class="body">
                                <span class="title">Monetizar tu audiencia</span
                                >
                                <span class="subtitle-hand"
                                    >convierte seguidores en clientes</span
                                >
                            </span>
                            <span class="arrow" aria-hidden="true">→</span>
                        </a>
                        */}

                        <div
                            class="block block--secondary block--sub block--sin-hueco"
                        >
                            <img
                                class="icon"
                                src="/imgs/svg/crane.svg"
                                alt="🏗️"
                            />
                            <span class="body">
                                <span class="title"
                                    >Ahora mismo no tengo hueco</span
                                >
                                <span class="subtitle-hand"
                                    >Pronto abriré</span
                                >
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <a
                class="block block--secondary"
                href="/claude"
                target="_blank"
                rel="noopener"
                draggable="false"
            >
                <span class="handle" aria-hidden="true">⋮⋮</span>
                <img class="icon" src="/imgs/svg/muscle.svg" alt="💪" />
                <span class="body">
                    <span class="title">Claude Code de 0 a 100</span>
                    <span class="subtitle-hand"
                        >trabaja como si tuvieras 100 brazos</span
                    >
                </span>
                <span class="badge">GRATIS</span>
                <span class="arrow" aria-hidden="true">→</span>
            </a>

            <!-- <a
                class="block block--secondary"
                href="/robame"
                target="_blank"
                rel="noopener"
                draggable="false"
            >
                <span class="handle" aria-hidden="true">⋮⋮</span>
                <img class="icon" src="/imgs/svg/money-bag.svg" alt="💰" />
                <span class="body">
                    <span class="title"
                        >Róbame hasta 19.970€ desde tu&nbsp;sofá</span
                    >
                    <span class="subtitle-hand">debo estar loco...</span>
                </span>
                <span class="arrow" aria-hidden="true">→</span>
            </a> -->
        </nav>
    </main>

    <Footer />

    <script
        is:inline
        src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"
    ></script>
    <script is:inline>
        Sortable.create(document.querySelector(".blocks"), {
            handle: ".handle",
            animation: 150,
            ghostClass: "block--ghost",
        });

        // Bloques-acordeón: el disparador despliega sus sub-opciones en vez de
        // navegar. El estado vive en aria-expanded; el CSS anima el despliegue.
        document.querySelectorAll(".block-toggle").forEach((btn) => {
            btn.addEventListener("click", () => {
                const abierto = btn.getAttribute("aria-expanded") === "true";
                btn.setAttribute("aria-expanded", String(!abierto));
            });
        });
    </script>
</BaseLayout>

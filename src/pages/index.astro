---
import BaseLayout from "../layouts/BaseLayout.astro";
import Footer from "../components/Footer.astro";
import { DESCRIPCION_19K } from "../data/bio.js";
---

<BaseLayout
    titulo="David Varea | Director de marketing en las sombras"
    canonical="/"
    ogTitle="🤝 David Varea"
    ogDescription={DESCRIPCION_19K}
    ogUrl="https://davidvarea.com"
>
    <main class="stage">
        <section class="hero-card">
            <div class="hero-photo-wrap">
                <img
                    class="hero-photo"
                    src="/imgs/profile-pic.webp"
                    alt="David Varea"
                />
            </div>

            <h1 class="hero-headline">
                Mis clientes han facturado
                <span class="hl-squiggle">
                    <span class="squiggle-text">2.4 millones</span>
                    <svg
                        class="squiggle-svg"
                        viewBox="0 0 140 10"
                        preserveAspectRatio="none"
                        aria-hidden="true"
                    >
                        <path
                            d="M2 5 Q 35 1 70 5 T 138 5"
                            stroke-width="2.4"
                            fill="none"
                            stroke-linecap="round"></path>
                    </svg>
                </span>
                de € con mi ayuda
            </h1>

            <div class="postit-wrap">
                <div class="postit">
                    <span class="tape" aria-hidden="true"></span>
                    Este título es para mí mismo, para
                    <span class="bold"
                        >fascinar al David Varea de hace 3 años.</span
                    >
                    No sabía ni qué significaba funnel y quiso ser autodidacta..
                </div>
            </div>
        </section>

        <span class="section-arrow" aria-hidden="true"></span>

        <div class="section-heading">
            <span class="caret">▾</span>
            ¿Qué te trae por aquí?
        </div>

        <nav class="blocks" aria-label="Secciones">
            <!-- <a
                class="block block--primary"
                href="/la-forja"
                target="_blank"
                rel="noopener"
                draggable="false"
            >
                <span class="handle" aria-hidden="true">⋮⋮</span>
                <img class="icon" src="/imgs/favicon-forja-48.png" alt="⚒️" />
                <span class="body">
                    <span class="title">LA FORJA</span>
                    <span class="subtitle-hand"
                        >crea tu ejercito de clones IA</span
                    >
                </span>
                <span class="arrow" aria-hidden="true">→</span>
            </a> -->

            <a
                class="block block--secondary"
                href="/servicios"
                target="_blank"
                rel="noopener"
                draggable="false"
            >
                <span class="handle" aria-hidden="true">⋮⋮</span>
                <img class="icon" src="/imgs/svg/handshake.svg" alt="🤝" />
                <span class="body">
                    <span class="subtitle-hand"
                        >director de marketing en las sombras</span
                    >
                    <span class="title">Mis servicios (o consultoría)</span>
                </span>
                <span class="arrow" aria-hidden="true">→</span>
            </a>

            <a
                class="block block--secondary"
                href="/cerebro"
                target="_blank"
                rel="noopener"
                draggable="false"
            >
                <span class="handle" aria-hidden="true">⋮⋮</span>
                <img class="icon" src="/imgs/svg/robot.svg" alt="🤖" />
                <span class="body">
                    <span class="title">Tengo un ejército de clones</span>
                    <span class="subtitle-hand">y te doy uno gratis</span>
                </span>
                <span class="badge">CLAUDE</span>
                <span class="arrow" aria-hidden="true">→</span>
            </a>

            <a
                class="block block--secondary"
                href="/robame"
                target="_blank"
                rel="noopener"
                draggable="false"
            >
                <span class="handle" aria-hidden="true">⋮⋮</span>
                <img class="icon" src="/imgs/svg/money-bag.svg" alt="💰" />
                <span class="body">
                    <span class="title"
                        >Róbame hasta 19.970€ desde tu&nbsp;sofá</span
                    >
                    <span class="subtitle-hand">debo estar loco...</span>
                </span>
                <span class="arrow" aria-hidden="true">→</span>
            </a>
        </nav>
    </main>

    <Footer />

    <script
        is:inline
        src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"
    ></script>
    <script is:inline>
        Sortable.create(document.querySelector(".blocks"), {
            handle: ".handle",
            animation: 150,
            ghostClass: "block--ghost",
        });
    </script>
</BaseLayout>

---
import OptinBase from "./OptinBase.astro";

/* Wrapper del optin para el nuevo lead magnet (skill de Claude vía
   Skool). Fija el form-id de MailerLite de esta oferta para que su
   automatización de bienvenida dispare por destino del submit, no por
   filtrado de UTMs posterior — los UTMs pueden faltar o llegar
   incorrectos; el form-id siempre llega correcto. */
const CLAUDESKOOL_FORM_ID = "191796601716475583";

/* Texto por defecto del botón para este lead magnet. La página puede
   overridearlo pasando `botonTexto`; el form-id se fija siempre después
   del spread para que la página no pueda cambiarlo. */
const { botonTexto = "Mándame gratis esos módulos", ...rest } = Astro.props;
---

<OptinBase {...rest} botonTexto={botonTexto} formId={CLAUDESKOOL_FORM_ID} />

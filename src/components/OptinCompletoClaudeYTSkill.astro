---
import OptinClaudeYTSkill from './OptinClaudeYTSkill.astro';
import PitchCerebro from './PitchCerebro.astro';

// Bloque opt-in del lead magnet "Cerebro" (Claude / IA). Foto + nombre +
// pitch + vídeo demo + form. Cierra los posts del blog de categoría "ia"
// (lo monta PostLayout) y puede insertarse mid-article en cualquier .mdx.
//
// El copy (pitch) vive en PitchCerebro, compartido con el hero de
// /cerebro: editar la pieza cambia landing y bloque a la vez.
//
// Comparte la clase `.optin-bloque` con los bloques de Róbame: layout,
// foto, nombre y tipografías se rigen por las mismas reglas CSS.
//
// `id` opcional: PostLayout pasa "post-end" cuando cierra el post; una
// inserción mid-article en un .mdx va sin id para no duplicar anchors.
const { id } = Astro.props;
---

<section class="optin-bloque" id={id}>
    <img
        class="hero-photo"
        src="/imgs/profile-pic.webp"
        alt="David Varea"
        loading="lazy"
    />
    <div>
        <p class="optin-bloque-nombre">David Varea</p>
        <PitchCerebro class="optin-bloque-pitch" />
    </div>

    <video
        class="hero-video"
        controls
        controlslist="nodownload"
        preload="none"
        playsinline
        poster="/videos/claude-skill-poster.webp"
        width="1920"
        height="1080"
    >
        <source src="/videos/claude-skill.webm" type="video/webm" />
        <source src="/videos/claude-skill.mp4" type="video/mp4" />
        Tu navegador no puede reproducir este vídeo.
    </video>

    <OptinClaudeYTSkill />
</section>

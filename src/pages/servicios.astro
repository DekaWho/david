---
import BaseLayout from "../layouts/BaseLayout.astro";
import Menu from "../components/Menu.astro";
import Footer from "../components/Footer.astro";
import Logros from "../components/Logros.astro";
import Reviews from "../components/Reviews.astro";
---

<BaseLayout
    titulo="Director de marketing en las sombras | David Varea"
    canonical="/servicios"
    ogTitle="🤝 David Varea"
    ogDescription="Director de marketing en las sombras (+LTV sin descuentos, -CAC sin gastar más en ads)"
    ogUrl="https://davidvarea.com/servicios"
>
    <Menu />

    <div class="banner">
        <section class="hero">
            <div class="hero-photo-wrap">
                <img
                    class="hero-photo"
                    src="/imgs/profile-pic.webp"
                    alt="David Varea"
                />
            </div>

            <h2>
                <img class="emoji" src="/imgs/svg/handshake.svg" alt="🤝" />
                David Varea
                <span class="banner-subline"
                    >(director de marketing en las sombras)</span
                >
            </h2>

            <h1>
                ENCÁRGAME UN MARRÓN Y
                <u class="banner-mark">LÍBRATE DE ÉL</u>
            </h1>

            <ul class="banner-badges" aria-label="Lo que entrego">
                <li class="banner-badge">
                    <svg
                        class="banner-badge-icon"
                        viewBox="0 0 400 400"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="10"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-opacity="0.9"
                        aria-hidden="true"
                    >
                        <path
                            d="M177.059 97C193.502 98.118 226.578 97 232.278 97C259.219 97 225.849 214.971 203.529 230.752C167.582 256.166 148.988 124.971 162.172 97"
                        ></path>
                        <path
                            d="M133.105 141.222C144.533 153.335 157.911 137.449 156.655 123.814C153.945 94.4261 121.86 86.1149 110.629 114.528C89.9652 166.803 143.794 187.108 167.629 212.948C172.548 218.282 172.745 228.942 178.332 235"
                        ></path>
                        <path
                            d="M259.023 142.873C248.727 153.846 231.968 142.498 235.642 128.268C248.288 79.2449 306.373 90.9972 291.97 141.749C279.509 185.66 214.81 191.856 208.007 235"
                        ></path>
                        <path
                            d="M184.786 240C185.231 252.663 181.663 264.32 173.695 273"
                        ></path>
                        <path
                            d="M203.454 234C202.853 249.181 205.493 262.888 210.789 275"
                        ></path>
                        <path
                            d="M211.716 277C211.286 280.712 212.232 298.356 210.842 300.759C210.351 301.605 193.961 302.519 191.945 302.643C186.642 302.972 173.695 304.079 173.695 299.49C173.695 290.946 173.695 285.577 173.695 277"
                        ></path>
                    </svg>
                    <span class="banner-badge-text">
                        <span class="banner-badge-label">Aumentar LTV</span>
                        <span class="banner-badge-qualifier"
                            >sin descuentos</span
                        >
                    </span>
                </li>
                <li class="banner-badge">
                    <svg
                        class="banner-badge-icon"
                        viewBox="0 0 400 400"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="14"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-opacity="0.9"
                        aria-hidden="true"
                    >
                        <path
                            d="M106.562 109.896C116.06 109.06 207.772 103.859 209.043 105.228C214.219 110.795 210.778 148.588 210.778 156.193C210.778 161.032 212.076 190.684 208.173 194.881C206.166 197.04 125.322 191.145 110.903 191.145"
                        ></path>
                        <path
                            d="M104.605 120.489C101.553 143.192 102.767 166.258 102.767 188.902"
                        ></path>
                        <path
                            opacity="0.503384"
                            d="M102.97 140C131.615 144.079 180.355 134.743 199.927 140.661"
                        ></path>
                        <path
                            opacity="0.503384"
                            d="M108.955 168.249C141.222 164.161 180.77 168.842 210.7 165.667"
                        ></path>
                        <path
                            opacity="0.503384"
                            d="M174.371 119.199C174.101 127.54 173.731 202.881 171.616 190.008"
                        ></path>
                        <path
                            opacity="0.503384"
                            d="M138.826 112.745C141.261 140.393 136.991 167.05 136.991 194.065"
                        ></path>
                        <path
                            d="M289.703 125.653C230.999 169.187 165.091 233.179 107.759 265.059"
                        ></path>
                        <path
                            d="M102.97 191.484C144.925 207.331 170.714 251.663 207.109 275.386"
                        ></path>
                        <path
                            d="M201.305 277.035C203.79 275.027 205.678 274.027 209.175 273.212C223.94 269.771 226.388 289.082 215.231 294.282C200.858 300.979 190.21 285.979 200.329 279.1"
                        ></path>
                        <path
                            d="M288.687 124.72C291.172 122.713 293.059 121.712 296.556 120.897C311.322 117.456 313.77 136.767 302.612 141.967C288.24 148.664 277.592 133.664 287.711 126.785"
                        ></path>
                        <path
                            d="M99.0991 271.486C137.352 261.403 105.509 315.905 92.8868 285.32C90.1332 278.648 89.9005 275.929 95.5502 272.409"
                        ></path>
                    </svg>
                    <span class="banner-badge-text">
                        <span class="banner-badge-label">Reducir CAC</span>
                        <span class="banner-badge-qualifier"
                            >sin gastar más en ads</span
                        >
                    </span>
                </li>
            </ul>

            <a href="#contacto" class="block block--primary">
                <span class="handle" aria-hidden="true">⋮⋮</span>
                <img class="icon" src="/imgs/svg/email.svg" alt="" />
                <span class="body">
                    <span class="title">Cómo trabajar juntos</span>
                </span>
            </a>
        </section>
    </div>

    <div class="cuerpo">
        <p>Hay dos tipos de marrones en todo negocio...</p>

        <ol>
            <li>
                El que ya tienes ubicado: Sabes qué falla y por dónde abordarlo.
            </li>
            <li>
                El que no consigues localizar: Algo no va bien pero no sabes
                exactamente por qué.
            </li>
        </ol>

        <p>
            <strong>
                El primero es fácil de resolver. Lo defines y alguien ejecuta
                (puedo ser yo o cualquier buen especialista). El segundo <u
                    class="mark-amarillo"
                    >es otra historia.
                </u>No se delega igual.
            </strong>
        </p>

        <p>
            Ahí no necesitas una mano más, necesitas una cabeza que ordene las
            prioridades y resuelva teniendo en mente <span
                class="squiggle squiggle--azul">lo que de verdad importa (</span
            >el beneficio por encima de la facturación)
        </p>

        <p>
            <strong>
                Un director de marketing pero sin el compromiso de tenerlo en
                nómina. Mejor uno en las sombras.
            </strong>
        </p>

        <p>
            Y no lo digo por decir. Yo he trabajado con ecommerce, infoproductos
            y en el sector financiero. Estos son algunos de mis logros en los
            últimos años:
        </p>

        <Logros />
    </div>

    <Reviews />

    <h1 class="titulo-breaker titulo-breaker--bg-claro">
        Cómo <span class="banner-mark">trabajar&nbsp;juntos</span>
    </h1>

    <div class="cuerpo">
        <p id="contacto">
            Ya sea como copywriter o como director de marketing freelance apunto
            a un solo objetivo <span class="azul">→</span> Mejorar el ratio
            <span class="ink-circle ink-circle--azul"
                >LTGP:CAC<svg
                    class="ink-circle-svg"
                    viewBox="0 0 100 60"
                    preserveAspectRatio="none"
                    aria-hidden="true"
                >
                    <path
                        d="M 52 6 C 80 7 96 19 94 33 C 93 49 76 55 50 56 C 23 56 6 48 6 30 C 7 14 25 5 52 6"
                        stroke="currentColor"
                        stroke-width="1.5"
                        fill="none"
                        stroke-linecap="round"></path></svg
                ></span
            >
            <strong>
                ¿Quién quiere facturar millones si el margen de beneficio queda
                minúsculo?
            </strong>
        </p>

        <p>
            <u class="mark-amarillo">A quién puedo ayudar: </u>A ecommerce,
            infoproductores o negocios que venden servicios. Si necesitan una de
            estas dos cosas...
        </p>

        <ul>
            <li>
                Un acompañamiento 1a1 para ganar claridad y ver cuál es el
                siguiente paso que más te acerca a <strong
                    >conseguir clientes que molesten poco, paguen mucho y encima
                    repitan.
                </strong>Te ofrezco una hoja de ruta personalizada para tu caso
                concreto y eres tú quien la ejecuta.
            </li>
            <li>
                Ya tienes claro qué necesita tu empresa a nivel de marketing y
                ventas pero <strong
                    >necesitas alguien que se encargue de ejecutar la misión.</strong
                >
            </li>
        </ul>

        <p>
            Rellenas el formulario para ver si puedo ayudarte. Te contacto sea
            cual sea la respuesta y concretamos el horario para una reunión por
            google meets.
        </p>

        <div class="diamond" aria-hidden="true"></div>

        <p class="titulo-mano">¿Tienes algo importante entre manos?</p>

        <div class="callout">
            <iframe
                data-tally-src="https://tally.so/embed/wz6vZ8?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
                loading="lazy"
                width="100%"
                height="387"
                frameborder="0"
                marginheight="0"
                marginwidth="0"
                title="Formulario de contacto"></iframe>
            <script is:inline>
                var d = document,
                    w = "https://tally.so/widgets/embed.js",
                    v = function () {
                        "undefined" != typeof Tally
                            ? Tally.loadEmbeds()
                            : d
                                  .querySelectorAll(
                                      "iframe[data-tally-src]:not([src])",
                                  )
                                  .forEach(function (e) {
                                      e.src = e.dataset.tallySrc;
                                  });
                    };
                if ("undefined" != typeof Tally) v();
                else if (d.querySelector('script[src="' + w + '"]') == null) {
                    var s = d.createElement("script");
                    ((s.src = w),
                        (s.onload = v),
                        (s.onerror = v),
                        d.body.appendChild(s));
                }
            </script>
        </div>

        <div class="flecha flecha--up" aria-hidden="true"></div>
    </div>

    <Footer />
</BaseLayout>

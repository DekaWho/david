---
import BaseLayout from "../layouts/BaseLayout.astro";

/*
  ANDAMIAJE — landing del acompañamiento high-ticket (hecho-contigo). Brief en
  ToDo/carta-ventas-acompanamiento.md. El copy de venta marcado PLACEHOLDER es
  decisión de David (paso 1 del brief: promesa, transformación, objeción de los
  1.000€). La prueba (logros + reviews) y el bloque del "segundo marrón" van
  reciclados de /servicios. Pendiente al activar: copy real, añadir a sitemap.xml,
  decidir si recibe tráfico de pago Meta (entonces montar FooterDisclaimer).
*/
---

<BaseLayout
    titulo="Acompañamiento de marketing | David Varea"
    canonical="/contigo"
    ogTitle="🤝 David Varea — acompañamiento de marketing"
    ogUrl="https://davidvarea.com/contigo"
>
    <div class="banner">
        <section class="hero">
            <div class="hero-photo-wrap">
                <img
                    class="hero-photo"
                    src="/imgs/profile-pic.webp"
                    alt="David Varea"
                />
            </div>

            <h2>
                <img class="emoji" src="/imgs/svg/handshake.svg" alt="🤝" />
                David Varea
                <span class="banner-subline"
                    >(director de marketing en las sombras)</span
                >
            </h2>

            {/* PLACEHOLDER hero — promesa hecho-contigo. NO delegación: el cliente
                ejecuta su marketing con tu criterio al lado. Reescribir. */}
            <h1>
                「PROMESA HERO PLACEHOLDER」
                <u class="banner-mark">HAZLO TÚ, CON MI CRITERIO AL LADO</u>
            </h1>

            <ul class="banner-badges" aria-label="Lo que entrego">
                <li class="banner-badge">
                    <svg
                        class="banner-badge-icon"
                        viewBox="61 60 280 280"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="10"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-opacity="0.9"
                        aria-hidden="true"
                    >
                        <path
                            d="M122 256.491C128.401 255.021 135.689 155.505 137.425 155.505C139.513 155.505 140.235 168.803 140.51 169.935C143.226 181.226 149.779 194.176 159.019 198.786C170.207 204.365 189.929 164.92 192.955 154.546C193.035 154.272 195.726 141.143 196.812 142.044C207.535 150.959 203.525 211.324 240.773 205.519C263.127 202.036 272.621 146.033 277.023 148.777C278.608 149.763 275.536 174.171 275.481 175.704C274.467 203.538 277.792 230.818 277.792 258.414C233.368 252.531 187.86 249.709 144.104 258.414"
                        ></path>
                    </svg>
                    <span class="banner-badge-text">
                        <span class="banner-badge-label">Aumentar LTV</span>
                        <span class="banner-badge-qualifier"
                            >sin descuentos</span
                        >
                    </span>
                </li>
                <li class="banner-badge">
                    <svg
                        class="banner-badge-icon"
                        viewBox="0 0 400 400"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="14"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-opacity="0.9"
                        aria-hidden="true"
                    >
                        <path
                            d="M152.526 134.8C236.161 72.4698 340.146 220.493 243.442 279.824C150.752 336.688 95.2145 229.357 141.097 149.303"
                        ></path>
                        <path
                            d="M259.155 125.382C277.229 99.2395 303.592 158.898 285.585 162.779"
                        ></path>
                        <path
                            d="M145.093 120.982C129.968 96.9319 97.8704 149.737 111.145 161.779"
                        ></path>
                        <path
                            d="M219.28 100C206.252 101.255 193.329 100 180.332 100"
                        ></path>
                        <path
                            d="M198.879 152.779C204.311 247.903 186.442 223.399 229.481 197.063"
                        ></path>
                        <path
                            d="M191.46 169.779C199.849 148.812 198.631 149.071 208.152 166.933"
                        ></path>
                        <path
                            d="M223.917 194.304C234.139 189.603 233.248 190.944 230.255 202.779"
                        ></path>
                        <path
                            d="M138.603 276.779C131.604 282.947 127.3 292.974 122.838 300.779"
                        ></path>
                        <path
                            d="M257.301 276.779C263.759 283.958 267.984 291.65 271.211 300.779"
                        ></path>
                    </svg>
                    <span class="banner-badge-text">
                        <span class="banner-badge-label">Reducir CAC</span>
                        <span class="banner-badge-qualifier"
                            >sin gastar más en ads</span
                        >
                    </span>
                </li>
            </ul>

            <a href="#contacto" class="block block--primary">
                <span class="handle" aria-hidden="true">⋮⋮</span>
                <img class="icon" src="/imgs/svg/email.svg" alt="" />
                <span class="body">
                    <span class="title">Quiero el acompañamiento</span>
                </span>
            </a>
        </section>
    </div>

    {/* Bloque "segundo marrón" — reciclado de /servicios. El brief lo marca como
        copy-puente que encaja MEJOR con acompañamiento que con delegación. Las dos
        últimas frases (nómina / "en las sombras") son framing de delegación:
        PLACEHOLDER para reescribir hacia hecho-contigo. */}
    <div class="cuerpo">
        <p>Hay dos tipos de marrones en todo negocio...</p>

        <ol>
            <li>
                El que ya tienes ubicado: Sabes qué falla y por dónde abordarlo.
            </li>
            <li>
                El que no consigues localizar: Algo no va bien pero no sabes
                exactamente por qué.
            </li>
        </ol>

        <p>
            <strong>
                El primero es fácil de resolver. Lo defines y alguien ejecuta
                (puedo ser yo o cualquier buen especialista). El segundo <u
                    class="mark-amarillo"
                    >es otra historia.
                </u>No se delega igual.
            </strong>
        </p>

        <p>
            Ahí no necesitas una mano más, necesitas una cabeza que ordene las
            prioridades y resuelva teniendo en mente <span
                class="squiggle squiggle">lo que de verdad importa (</span
            >el beneficio por encima de la facturación)
        </p>

        <p>
            <strong>
                Un director de marketing pero sin el compromiso de tenerlo en
                nómina. Mejor uno en las sombras.
            </strong>
        </p>

        <p>
            Y no lo digo por decir. Yo he trabajado con ecommerce,
            infoproductos y en el sector financiero. Estos son algunos de mis
            logros en los últimos años:
        </p>

        <div class="aviso-mano">
            <span class="aviso-mano-icono" aria-hidden="true"></span>
            <p>
                Tanto si fui <u>estratega</u> como <u>copywriter</u> estos resultados
                son fruto del trabajo en equipo
            </p>
        </div>

        <ul class="bold-odd" style="margin-bottom: var(--gap-3xl)">
            <li>
                560 pedidos en 14 minutos. Ese fue el resultado de un email
                único enviado al segmento de no compradores de un ecommerce. Sin
                hype previo ni secuencia de calentamiento.
            </li>

            <li>
                Aunque publicitarse en TV es cosa del pasado, escribí el copy
                para un anuncio que se emitió en A3Media. Durante diversos
                programas como Pasapalabra o El intermedio.
            </li>

            <li class="logro--email">
                Tasa de apertura entorno al 35% (si miramos solo segmento de
                clientes tasa de apertura hasta el 60%) en campañas de email
                marketing (Klaviyo) para una lista de un ecommerce con más de
                340.000 emails.
            </li>

            <li>
                Escribí una landing para tráfico frío sin poder usar prueba
                social u otro tipo de autoridad de marca. Un MVP para testear si
                un nuevo ecommerce tenía tracción en ese mercado. Tuvo un 33.9% de
                añadido al carrito.
            </li>

            <li>
                El primer mes que entré en una fintech (para implementar la
                estrategia de email diario) batió su propio récord de
                facturación mensual.
            </li>

            <li>
                Junto a Chuso Montero levantamos su canal de YouTube desde 0
                hasta 109K seguidores. En el nicho videojuegos, durante la época
                más saturada del sector (2020 - 2022). Generando no solo visitas
                sino una audiencia fiel y recurrente.
            </li>

            <li>
                Facturación de 6 cifras con un par de emails que se enviaron
                durante 48h vendiendo un producto low ticket.
            </li>

            <li>
                Más de 100 Millones de reproducciones en total (en vídeos
                horizontales orgánicos) trabajando con varios youtubers de
                entretenimiento.
            </li>

            <li>
                Hice los emails de una campaña que redujo el CAC un 39.8%
                respecto a los meses anteriores, despertando leads zombie
                (estaban en la lista meses sin haber comprado nada)
            </li>

            <li class="logro--flag">
                He ayudado a mis clientes a facturar más de 2.4 millones de €
            </li>
        </ul>
    </div>

    <h1 class="titulo-breaker titulo-breaker--bg-oscuro" id="reviews">
        Pero
        <span class="ink-circle"
            >no<svg
                class="ink-circle-svg"
                viewBox="0 0 100 60"
                preserveAspectRatio="none"
                aria-hidden="true"
            >
                <path
                    d="M 52 6 C 80 7 96 19 94 33 C 93 49 76 55 50 56 C 23 56 6 48 6 30 C 7 14 25 5 52 6"
                    stroke="currentColor"
                    stroke-width="3"
                    fill="none"
                    stroke-linecap="round"></path></svg
            ></span
        >
        te fíes de <span class="squiggle">mis&nbsp;palabras</span>
    </h1>

    <section class="seccion-tinta seccion-tinta--separada">
        <div class="cuerpo">
            <div class="player-container review-card">
                <img class="avatar" src="/reviews/pascu.webp" />

                <audio controls controlslist="nodownload noplaybackrate">
                    <source src="/reviews/pascu.mp3" type="audio/mpeg" />
                    Tu navegador no soporta audio HTML5.
                </audio>
            </div>

            <p>
                Esto es lo que dice
                <span class="squiggle squiggle--alt"
                    >Pascual Cabedo, fundador de EAP.
                </span>Uno de los ecommerce de alimentación más grandes de
                España.
            </p>

            <p>
                <strong>
                    +220.000 clientes con alta recurrencia, +8 millones de kilos
                    de alimento enviados y millones de visitas en redes sociales
                    (venden online producto de agricultores españoles, sin
                    químicos post-cosecha)
                </strong>
            </p>

            <div class="player-container review-card">
                <img class="avatar" src="/reviews/gon.webp" />

                <audio controls controlslist="nodownload noplaybackrate">
                    <source src="/reviews/gon.mp3" type="audio/mpeg" />
                    Tu navegador no soporta audio HTML5.
                </audio>
            </div>

            <p>
                <span class="squiggle squiggle--alt"
                    >Gonzalo Zahonero es asesor financiero.
                </span>Hemos trabajado juntos en campañas sobre finanzas y
                trading. Te contaría más al respecto pero tenemos acuerdos de
                confidencialidad que nos impiden ████████ █████ █████ ██
                ████████
            </p>

            <div class="player-container review-card review-card--chat">
                <img class="avatar" src="/reviews/rioboo.webp" />

                <audio controls controlslist="nodownload noplaybackrate">
                    <source src="/reviews/rioboo.mp3" type="audio/mpeg" />
                    Tu navegador no soporta audio HTML5.
                </audio>
            </div>

            <p>
                Él es <span class="squiggle"
                    >Rioboo, cofundador de Cori Coffee.
                </span>Aunque no sigas el mundo influencer igual te suena por
                haberlo visto trabajar junto a Ibai (o porque IlloJuan y Borja
                Iglesias han bebido este café y lo han enseñado en sus redes)
            </p>
        </div>
    </section>

    <div class="cuerpo">
        <p>
            Ahora podría abrumarte con más reseñas positivas incluyendo las de
            mis padres pero...
        </p>
        <h2 class="suficiente">SUFICIENTE</h2>

        <div class="flecha flecha--down flecha--alt" aria-hidden="true"></div>
    </div>

    {/* Sección OFERTA — los datos son los del brief (decididos). El framing de
        venta alrededor es PLACEHOLDER. */}
    <h1 class="titulo-breaker titulo-breaker--bg-claro">
        En qué consiste el <span class="banner-mark">acompañamiento</span>
    </h1>

    <div class="cuerpo">
        {/* PLACEHOLDER intro oferta: qué transformación compra el cliente en 1 mes. */}
        <p>
            「INTRO OFERTA PLACEHOLDER: presenta la oferta como una relación de
            un mes con tu criterio al lado, no una auditoría suelta ni
            delegación.」
        </p>

        <ul class="bold-odd">
            <li>1 mes de acompañamiento.</li>
            <li>1 llamada de 2h por semana (4 al mes).</li>
            <li>Dudas breves por WhatsApp de lunes a viernes.</li>
            <li>1.000€ + IVA al mes.</li>
        </ul>

        {/* PLACEHOLDER objeción central (brief): "¿merece pagar 1.000€/mes por
            acceso a su criterio, cuando podría buscármelo gratis o montármelo
            solo?". Es el núcleo persuasivo de esta carta. Reescribir. */}
        <p>
            <strong>
                「OBJECIÓN PLACEHOLDER: por qué pagar 1.000€/mes por criterio al
                lado en vez de montártelo solo o buscarlo gratis.」
            </strong>
        </p>

        <div class="diamond" aria-hidden="true"></div>
    </div>

    <h1 class="titulo-breaker titulo-breaker--bg-claro">
        Cómo <span class="banner-mark">empezamos</span>
    </h1>

    <div class="cuerpo">
        {/* CTA = form de Tally (filtro previo a la reunión). David contacta para
            agendar. Reusa el embed de /servicios; si quieres separar estos leads
            de los de servicios-b2b, crea un form de Tally propio y cambia el
            data-tally-src. */}
        <p id="contacto">
            「CIERRE PLACEHOLDER: invita a rellenar el formulario para valorar el
            encaje antes de la llamada.」
        </p>

        <p class="titulo-mano">¿Quieres trabajar tu marketing conmigo al lado?</p>

        <div class="callout">
            <iframe
                data-tally-src="https://tally.so/embed/wz6vZ8?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
                loading="lazy"
                width="100%"
                height="387"
                frameborder="0"
                marginheight="0"
                marginwidth="0"
                title="Formulario de contacto"></iframe>
            <script is:inline>
                var d = document,
                    w = "https://tally.so/widgets/embed.js",
                    v = function () {
                        "undefined" != typeof Tally
                            ? Tally.loadEmbeds()
                            : d
                                  .querySelectorAll(
                                      "iframe[data-tally-src]:not([src])",
                                  )
                                  .forEach(function (e) {
                                      e.src = e.dataset.tallySrc;
                                  });
                    };
                if ("undefined" != typeof Tally) v();
                else if (d.querySelector('script[src="' + w + '"]') == null) {
                    var s = d.createElement("script");
                    ((s.src = w),
                        (s.onload = v),
                        (s.onerror = v),
                        d.body.appendChild(s));
                }
            </script>
        </div>

        <div class="flecha flecha--up" aria-hidden="true"></div>
    </div>
</BaseLayout>

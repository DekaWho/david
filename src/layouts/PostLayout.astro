---
import Head from '../components/Head.astro';
import Firma from '../components/Firma.astro';
import { categorias } from '../data/categorias.js';

// frontmatter del .mdx llega bajo Astro.props.frontmatter; en .astro
// llega como props directas. Soportamos las dos formas.
const {
  titulo,
  readingTime = 2,
  ...headProps
} = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <Head titulo={titulo} {...headProps} ogType={headProps.ogType ?? 'article'} favicon={headProps.favicon ?? 'writing'} />
  </head>
  <body class="post">
    <aside class="post-toc" aria-label="Índice de esta página">
      <input
        type="checkbox"
        id="post-toc-checkbox"
        aria-label="Abrir índice de esta página"
      />
      <label for="post-toc-checkbox" class="burger" aria-hidden="true">
        <span></span><span></span><span></span>
      </label>
      <div class="post-toc-panel">
        <p class="post-toc-title">Más artículos</p>
        <ul class="post-toc-otros">
          {categorias.map((cat) => (
            <li><a href={`/blog#${cat.slug}`}>Sobre {cat.nombre}</a></li>
          ))}
        </ul>

        <p class="post-toc-title post-toc-title--indice">Índice de esta página</p>
        <ol class="post-toc-list"></ol>
      </div>
    </aside>

    <div class="banner">
      <section class="hero">
        <slot name="hero-title"><h1 id="post-top">{titulo}</h1></slot>
        <p class="post-meta">
          <time id="post-fecha"></time> · {readingTime} min de lectura
        </p>
        <div class="postit-wrap">
          <div class="postit">
            <span class="tape" aria-hidden="true"></span>
            <strong>Escrito sin IA.</strong> La IA es genial para muchas cosas
            pero no quiero que pierdas el tiempo leyendo frases de relleno y
            palabrería vacía.
          </div>
        </div>
      </section>
    </div>

    <article class="cuerpo">
      <slot />
    </article>

    <Firma id="post-end" />

    <script is:inline>
      const fechaEl = document.getElementById("post-fecha");
      if (fechaEl) {
        const meses = [
          "enero",
          "febrero",
          "marzo",
          "abril",
          "mayo",
          "junio",
          "julio",
          "agosto",
          "septiembre",
          "octubre",
          "noviembre",
          "diciembre",
        ];
        const ahora = new Date();
        fechaEl.textContent =
          meses[ahora.getMonth()] + " de " + ahora.getFullYear();
      }
    </script>
  </body>
</html>

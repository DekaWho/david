---
/* HTML/CSS y comportamiento base del optin del sitio. NO incrustar
   directamente en una página: cada lead magnet vive en su propio wrapper
   (OptinRobame, OptinCerebro, …) que fija el form-id de MailerLite para
   que la automatización de bienvenida correcta dispare por destino del
   submit, no por filtrado de UTMs posterior.

   El handler de submit y la captura de atribución (utm_source/medium/
   content + referrer + ultimo_optin) viven en public/scripts/scripts.js
   — se enganchan por el selector form[data-ml-form-id], así que este
   componente no necesita props ni código para participar. Ver
   web-code/CLAUDE.md → "Integraciones externas → MailerLite → Atribución
   de origen" antes de añadir campos o tocar el sistema. */

const {
    id,
    formId,
    successUrl = "/not-done",
    botonTexto = "Recibir gratis los valiosos emails",
    botonIcono = "/imgs/svg/email.svg",
    mostrarPrivacyNote = true,
    // `cerrado`: estado "plazas cerradas". El cajetín se ve pero queda inerte
    // (sin data-ml-form-id, input y botón disabled) bajo la cinta de obras y
    // un cartel. El handler de scripts.js solo engancha form[data-ml-form-id],
    // así que al omitirlo el optin deja de postear a MailerLite.
    cerrado = false,
} = Astro.props;

if (!formId) {
    throw new Error(
        "OptinBase.astro: prop `formId` requerida. No incrustar este componente directamente — usar <OptinRobame /> u <OptinCerebro /> (o crear un nuevo wrapper si toca otro lead magnet)."
    );
}
---

<form
    class:list={["optin", { "optin--cerrado": cerrado }]}
    id={id}
    data-ml-form-id={cerrado ? undefined : formId}
    data-ml-success={cerrado ? undefined : successUrl}
>
    <label>
        <span class="visually-hidden">Email</span>
        <input
            type="email"
            name="email"
            placeholder="tucorreo@email.com"
            autocomplete="email"
            required
            disabled={cerrado}
        />
    </label>
    {
        mostrarPrivacyNote && !cerrado && (
            <p class="privacy-note">
                Puedes leer las burocráticas políticas de privacidad
                <a href="/privacidad" target="_blank" rel="noopener">
                    aquí
                </a>
            </p>
        )
    }
    <button type="submit" class="block block--primary" disabled={cerrado}>
        <img class="icon" src={botonIcono} alt="" />
        <span class="body">
            <span class="title">{botonTexto}</span>
        </span>
    </button>
    {cerrado && <span class="optin-cerrado-cartel">Acceso cerrado</span>}
</form>

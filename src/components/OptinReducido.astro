---
import OptinRobame from './OptinRobame.astro';

// Variante reducida del bloque opt-in autoral. Foto + nombre + cierre
// Kalam + form. Sin el párrafo serif "Me he gastado 19.970€…" ni la
// captura de las carpetas. Pensada para el cierre de los posts del blog
// (el lector ya leyó el artículo entero) y cualquier otro contexto donde
// el porqué del CTA ya esté establecido y solo haga falta el cierre.
// Para mid-article u otros sitios sin contexto previo, usar
// OptinCompleto.astro.
//
// Comparte la clase `.optin-bloque` con la variante completa: layout,
// foto, nombre y párrafo Kalam se rigen por las mismas reglas CSS.
const { id } = Astro.props;
---

<section class="optin-bloque" id={id}>
    <img
        class="hero-photo"
        src="/imgs/profile-pic.webp"
        alt="David Varea"
        loading="lazy"
    />
    <div>
        <p class="optin-bloque-nombre">David Varea</p>
        <p class="hand">
            Róbame hasta 19.970€ desde el sofá de tu casa mirando el móvil
        </p>
    </div>

    <OptinRobame />
</section>

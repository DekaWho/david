---
const {
  enlaces = [
    { href: '/', label: 'Portada', iconoCasa: true },
    { href: '#contacto', label: 'Contacto', flechaDer: '↓' },
  ],
} = Astro.props;
---
<nav class="menu" aria-label="Navegación principal">
  <input type="checkbox" id="menu-toggle" aria-label="Abrir menú" />
  <label for="menu-toggle" class="burger" aria-hidden="true">
    <span></span><span></span><span></span>
  </label>
  <div class="links">
    {enlaces.map((link, i) => (
      <>
        {i > 0 && <span class="menu-divider" aria-hidden="true">|</span>}
        <a href={link.href} class="menu-link">
          {link.iconoCasa && (
            <svg class="menu-link-icon" viewBox="0 0 1024 1024" fill="currentColor" aria-hidden="true">
              <path d="M192 413.952V896h640V413.952L512 147.328 192 413.952zM139.52 374.4l352-293.312a32 32 0 0 1 40.96 0l352 293.312A32 32 0 0 1 896 398.976V928a32 32 0 0 1-32 32H160a32 32 0 0 1-32-32V398.976a32 32 0 0 1 11.52-24.576z"/>
            </svg>
          )}
          <span>{link.label}</span>
          {link.flechaDer && (
            <span class="menu-link-arrow" aria-hidden="true">{link.flechaDer}</span>
          )}
        </a>
      </>
    ))}
  </div>
</nav>

---
const {
  enlaces = [
    { href: '/', label: 'Inicio', flechaIzq: '←' },
    { href: '#contacto', label: 'Contacto', flechaDer: '↓' },
  ],
} = Astro.props;
---
<nav class="menu" aria-label="Navegación principal">
  <input type="checkbox" id="menu-toggle" aria-label="Abrir menú" />
  <label for="menu-toggle" class="burger" aria-hidden="true">
    <span></span><span></span><span></span>
  </label>
  <div class="links">
    {enlaces.map((link, i) => (
      <>
        {i > 0 && <span class="menu-divider" aria-hidden="true">|</span>}
        <a href={link.href} class="menu-link">
          {link.flechaIzq && (
            <span class="menu-link-arrow" aria-hidden="true">{link.flechaIzq}</span>
          )}
          <span>{link.label}</span>
          {link.flechaDer && (
            <span class="menu-link-arrow" aria-hidden="true">{link.flechaDer}</span>
          )}
        </a>
      </>
    ))}
  </div>
</nav>

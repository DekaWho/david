---
import OptinRobame from './OptinRobame.astro';
import PitchRobame from './PitchRobame.astro';
import ProofRobame from './ProofRobame.astro';
import CierreRobame from './CierreRobame.astro';

// Bloque opt-in completo de Róbame. Foto + nombre + pitch serif + imagen
// de prueba + cierre Kalam + form. Es el optin con todo el contexto: lo
// monta el hero de /robame y el cierre de los posts del blog, y se inserta
// mid-article donde el lector aún no conoce la oferta. Cuando solo hace
// falta repetir el CTA (contexto ya dado), usar el cajetín suelto: el
// wrapper OptinRobame (input + botón), que es como se intercala en la landing.
//
// El copy (pitch, imagen, cierre) vive en los componentes Pitch/Proof/
// CierreRobame, compartidos con el hero de /robame: editar la pieza
// cambia landing y bloques a la vez.
//
// `id` opcional: PostLayout pasa "post-end" cuando una variante cierra el
// post; los .mdx insertan esta versión completa sin id para no duplicar
// anchors.
const { id } = Astro.props;
---

<section class="optin-bloque" id={id}>
    <img
        class="hero-photo"
        src="/imgs/profile-pic.webp"
        alt="David Varea"
        loading="lazy"
    />
    <div>
        <p class="optin-bloque-nombre">David Varea</p>
        <PitchRobame class="optin-bloque-pitch" />
    </div>

    <ProofRobame />
    <CierreRobame />

    <OptinRobame />
</section>
